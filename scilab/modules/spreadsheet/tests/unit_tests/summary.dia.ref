// table containing booleans and strings
t = table([%t; %f; %t], [%f; %t; %f], ["a"; "b"; "a"], ["b"; "b"; "bb"]);
summary(t)
 table: [3x4 table]
 Variables:
     Var1: boolean
     Var2: boolean
     Var3: string
     Var4: string
 Statistics for booleans:
           Var1   Var2
           ____   ____
                      
    True   2      1   
   False   1      2   
 Statistics for strings:
              Var3         Var4   
            _________   __________
                                  
   Values   ["a";"b"]   ["b";"bb"]
   Counts   [2;1]       [2;1]     
s = summary(t)
 s = [struct] with fields:
  Var1: [struct] with fields:
      Size = [3,1]
      Type = "boolean"
      Description = ""
      Units = ""
      True = 2
      False = 1
  Var2: [struct] with fields:
      Size = [3,1]
      Type = "boolean"
      Description = ""
      Units = ""
      True = 1
      False = 2
  Var3: [struct] with fields:
      Size = [3,1]
      Type = "string"
      Description = ""
      Units = ""
      NumMissing = 0
      Values = ["a";"b"]
      Counts = [2;1]
  Var4: [struct] with fields:
      Size = [3,1]
      Type = "string"
      Description = ""
      Units = ""
      NumMissing = 0
      Values = ["b";"bb"]
      Counts = [2;1]
assert_checkequal(s.Var1.Size, [3 1]);
assert_checkequal(s.Var2.Size, [3 1]);
assert_checkequal(s.Var3.Size, [3 1]);
assert_checkequal(s.Var4.Size, [3 1]);
assert_checkequal(s.Var1.Type, "boolean");
assert_checkequal(s.Var2.Type, "boolean");
assert_checkequal(s.Var3.Type, "string");
assert_checkequal(s.Var4.Type, "string");
// timeseries
T = datetime(2022, 12, 1:5)';
AmbientTemperature = [18; 18.5; 20; 20.2; 20.5];
FlowRate = [50; 52; 53; 55; 60];
ts = timeseries(T, AmbientTemperature, FlowRate)
 ts = [5x2 timeseries]
      Time      Var1   Var2
   __________   ____   ____
                           
   2022-12-01   18     50  
   2022-12-02   18.5   52  
   2022-12-03   20     53  
   2022-12-04   20.2   55  
   2022-12-05   20.5   60  
summary(ts)
 timeseries: [5x2 timeseries]
 RowTimes:
    Time: datetime
        StartTime: 2022-12-01
        SampleRate: 0.0000116
        TimeStep: 24:00:00
        NumMissing: 0
        Min: 2022-12-01
        Median: 2022-12-03
        Max: 2022-12-05
        Mean: 2022-12-03
        Std: 37:56:50.394
