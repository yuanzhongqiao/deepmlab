// <-- CLI SHELL MODE -->
// unit tests for summary function
// =============================================================================
// table with only doubles
t = table([1 2 3; 4 5 6; 7 8 9]);
summary(t)
 table: [3x3 table]
 Variables:
     Var1: double
     Var2: double
     Var3: double
 Statistics for numeric data:
                Var1   Var2   Var3
                ____   ____   ____
                                  
   NumMissing   0      0      0   
          Min   1      2      3   
       Median   4      5      6   
          Max   7      8      9   
         Mean   4      5      6   
          Std   3      3      3   
s = summary(t)
 s = [struct] with fields:
  Var1: [struct] with fields:
      Size = [3,1]
      Type = "double"
      Description = ""
      Units = ""
      NumMissing = 0
      Min = 1
      Median = 4
      Max = 7
      Mean = 4
      Std = 3
  Var2: [struct] with fields:
      Size = [3,1]
      Type = "double"
      Description = ""
      Units = ""
      NumMissing = 0
      Min = 2
      Median = 5
      Max = 8
      Mean = 5
      Std = 3
  Var3: [struct] with fields:
      Size = [3,1]
      Type = "double"
      Description = ""
      Units = ""
      NumMissing = 0
      Min = 3
      Median = 6
      Max = 9
      Mean = 6
      Std = 3
assert_checkequal(s.Var1.Size, [3 1]);
assert_checkequal(s.Var2.Size, [3 1]);
assert_checkequal(s.Var3.Size, [3 1]);
assert_checkequal(s.Var1.Type, "double");
assert_checkequal(s.Var2.Type, "double");
assert_checkequal(s.Var3.Type, "double");
t.Properties.VariableNames = ["a", "b", "c"];
summary(t)
 table: [3x3 table]
 Variables:
     a: double
     b: double
     c: double
 Statistics for numeric data:
                 a     b     c 
                ___   ___   ___
                               
   NumMissing   0     0     0  
          Min   1     2     3  
       Median   4     5     6  
          Max   7     8     9  
         Mean   4     5     6  
          Std   3     3     3  
s = summary(t)
 s = [struct] with fields:
  a: [struct] with fields:
      Size = [3,1]
      Type = "double"
      Description = ""
      Units = ""
      NumMissing = 0
      Min = 1
      Median = 4
      Max = 7
      Mean = 4
      Std = 3
  b: [struct] with fields:
      Size = [3,1]
      Type = "double"
      Description = ""
      Units = ""
      NumMissing = 0
      Min = 2
      Median = 5
      Max = 8
      Mean = 5
      Std = 3
  c: [struct] with fields:
      Size = [3,1]
      Type = "double"
      Description = ""
      Units = ""
      NumMissing = 0
      Min = 3
      Median = 6
      Max = 9
      Mean = 6
      Std = 3
assert_checkequal(fieldnames(s), ["a"; "b"; "c"]);
assert_checkequal(s.a.Size, [3 1]);
assert_checkequal(s.b.Size, [3 1]);
assert_checkequal(s.c.Size, [3 1]);
assert_checkequal(s.a.Type, "double");
assert_checkequal(s.b.Type, "double");
assert_checkequal(s.c.Type, "double");
t.Properties.VariableDescriptions = ["field a", "", "field c"];
summary(t)
