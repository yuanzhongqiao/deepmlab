// table containing doubles, datetimes, durations
t = table([1;2;3], datetime(2025, 12, [10; 11; 12]), hours([1;2;3]));
summary(t)
 table: [3x3 table]
 Variables:
     Var1: double
     Var2: datetime
     Var3: duration
 Statistics for numeric data:
                Var1      Var2        Var3  
                ____   __________   ________
                                            
   NumMissing   0      0            0       
          Min   1      2025-12-10   01:00:00
       Median   2      2025-12-11   02:00:00
          Max   3      2025-12-12   03:00:00
         Mean   2      2025-12-11   02:00:00
          Std   1      24:00:00     01:00:00
s = summary(t)
 s = [struct] with fields:
  Var1: [struct] with fields:
      Size = [3,1]
      Type = "double"
      Description = ""
      Units = ""
      NumMissing = 0
      Min = 1
      Median = 2
      Max = 3
      Mean = 2
      Std = 1
  Var2: [struct] with fields:
      Size = [3,1]
      Type = "datetime"
      Description = ""
      Units = ""
      NumMissing = 0
      Min: [datetime]
      Median: [datetime]
      Max: [datetime]
      Mean: [datetime]
      Std: [duration]
  Var3: [struct] with fields:
      Size = [3,1]
      Type = "duration"
      Description = ""
      Units = ""
      NumMissing = 0
      Min: [duration]
      Median: [duration]
      Max: [duration]
      Mean: [duration]
      Std: [duration]
assert_checkequal(s.Var1.Size, [3 1]);
assert_checkequal(s.Var2.Size, [3 1]);
assert_checkequal(s.Var3.Size, [3 1]);
assert_checkequal(s.Var1.Type, "double");
assert_checkequal(s.Var2.Type, "datetime");
assert_checkequal(s.Var3.Type, "duration");
t.Properties.VariableNames = ["a", "b", "c"];
