<refentry xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink"
          xmlns:svg="http://www.w3.org/2000/svg" xmlns:mml="http://www.w3.org/1998/Math/MathML"
          xmlns:db="http://docbook.org/ns/docbook" xmlns:scilab="http://www.scilab.org"
          xml:lang="en" xml:id="atomsAutoload">
    <refnamediv>
        <refname>atomsAutoload</refname>
        <refpurpose>Load the modules marked as "autoload"</refpurpose>
    </refnamediv>
    <!-- ===================================================================== -->
    <!-- Syntax -->
    <!-- ===================================================================== -->
    <refsynopsisdiv>
        <title>Syntax</title>
        <synopsis>
            modules = atomsAutoload()
        </synopsis>
    </refsynopsisdiv>
    <!-- ===================================================================== -->
    <!-- Parameters -->
    <!-- ===================================================================== -->
    <refsection>
        <title>Arguments</title>
        <variablelist>
            <varlistentry>
                <term>modules</term>
                <listitem>
                    <para>
                        m x 4 matrix of strings
                    </para>
                    <informaltable border="1">
                        <tr>
                            <th>1st Col.</th>
                            <th>2nd Col.</th>
                            <th>3rd Col.</th>
                            <th>4th Col.</th>
                        </tr>
                        <tr>
                            <td>Technical name</td>
                            <td>Version</td>
                            <td>Installed section</td>
                            <td>Installation path</td>
                        </tr>
                    </informaltable>
                </listitem>
            </varlistentry>
        </variablelist>
    </refsection>
    <!-- ===================================================================== -->
    <!-- Description -->
    <!-- ===================================================================== -->
    <refsection>
        <title>Description</title>
        <para>
            <literal>atomsAutoload</literal> returns the list of modules registered to autoload
        </para>
    </refsection>
    <!-- ===================================================================== -->
    <!-- Examples -->
    <!-- ===================================================================== -->
    <refsection>
        <title>Examples</title>
        <programlisting role="example"><![CDATA[
// Load the test repository
exec("SCI/modules/atoms/tests/unit_tests/atomsTestUtils.sce", -1);
repository = atomsCreateTestRepository("scene10");

atomsInstall("toolbox_1V6");

atomsAutoload()

// Cleaning
atomsRemove("toolbox_1V6");
atomsRepositoryDel(repository);
atomsSystemUpdate();

// Please restart Scilab to remove installed module
        ]]></programlisting>
    </refsection>
    <!-- ===================================================================== -->
    <!-- See also -->
    <!-- ===================================================================== -->
    <refsection role="see also">
        <title>See also</title>
